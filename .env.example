# Bee node used by `upload` (the node that stores the data).
BEE_UPLOAD_URL=http://localhost:1633

# Bee node used by `serial-download` / `burst-download`.
# Point this at a DIFFERENT node than BEE_UPLOAD_URL so chunks are fetched
# over the network and cheques (BZZ cost) are actually issued.
BEE_DOWNLOAD_URL=http://localhost:1633

# Postage batch id used by `upload`. Must be a usable, non-expired batch.
SWARM_BATCH_ID=
