  "description": "Reproducible, ad-hoc measurement tools for Swarm download bandwidth and BZZ cost.",
  "type": "module",
  "bin": {
    "swarm-bench": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && tsup",
